{
  "manifest_version": 3,
  "name": "Shelfie",
  "version": "0.1.0",
  "description": "Version-controlled shopping profiles for Myntra.",
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": ["https://www.myntra.com/*", "http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.myntra.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.myntra.com/*"],
      "js": ["inpage-panel.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.myntra.com/*"],
      "js": ["main-world-interceptor.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inpage-panel.css"],
      "matches": ["https://www.myntra.com/*"]
    }
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open Shelfie"
  }
}
